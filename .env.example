# ============================================================
# ResumeRank — Environment Variables
# Copy to .env and fill in real values before running.
# ============================================================

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resumerank
DB_HOST=localhost
DB_PORT=5432
DB_NAME=resumerank
DB_USER=postgres
DB_PASSWORD=postgres

# --- Spring Boot Backend ---
SERVER_PORT=8080
JWT_SECRET=change-me-to-a-64-char-random-string-in-production
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=http://localhost:3000
AI_SERVICE_URL=http://localhost:8000

# --- FastAPI AI Service ---
AI_SERVICE_PORT=8000

# --- Next.js Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080
